entidade alarme alarme_casa = alarm_control_panel.alarmo;
entidade luz sala = light.sala;
entidade interruptor tomada_tv = switch.tomada_tv;

automacao "Casa desarmada" {
    quando estado alarme_casa ficar disarmed;
    se estado sala ficar off e nao estado tomada_tv ficar on;

    faca {
        ligar sala;
        ligar tomada_tv;
    }

    modo queued;
}
