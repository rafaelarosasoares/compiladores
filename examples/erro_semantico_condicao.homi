entidade sensor movimento = binary_sensor.movimento;
entidade luz corredor = light.corredor;
entidade interruptor tomada = switch.tomada;

automacao "Erro semantico condicao" {
    quando estado movimento ficar on;
    se estado corredor ficar off e estado tomada ficar off ou nao estado movimento ficar off;

    faca {
        ligar corredor;
    }

    modo restart;
}
